<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Portfolio</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- Navigation -->
<header>
    <nav>
        <h2 class="logo">My Portfolio</h2>
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#education">Education</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>

<!-- Home -->
<section id="home" class="home">
    <img src="https://via.placeholder.com/180" alt="Profile Image">
    <h1>Hello, I'm m kurmarao</h1>
    <p>Web Developer | Student | Programmer</p>
</section>

<!-- About -->
<section id="about">
    <h2>About Me</h2>
    <p>
        I am a passionate web developer with knowledge of HTML, CSS,
        JavaScript, and responsive web design. I enjoy creating
        attractive and user-friendly websites.
    </p>
</section>

<!-- Skills -->
<section id="skills">
    <h2>Skills</h2>

    <div class="skill">
        <p>HTML</p>
        <div class="progress">
            <div class="bar html">90%</div>
        </div>
    </div>

    <div class="skill">
        <p>CSS</p>
        <div class="progress">
            <div class="bar css">85%</div>
        </div>
    </div>

    <div class="skill">
        <p>JavaScript</p>
        <div class="progress">
            <div class="bar js">80%</div>
        </div>
    </div>
</section>

<!-- Education -->
<section id="education">
    <h2>Education</h2>

    <div class="card">
        <h3>B.Tech in information technolgy</h3>
        <p>XYZ College</p>
        <p>2022 - 2026</p>
    </div>
</section>

<!-- Projects -->
<section id="projects">
    <h2>Projects</h2>

    <div class="project-container">

        <div class="project-card">
            <h3>Portfolio Website</h3>
            <p>Responsive portfolio using HTML, CSS & JavaScript.</p>
        </div>

        <div class="project-card">
            <h3>Calculator</h3>
            <p>Simple calculator with JavaScript.</p>
        </div>

        <div class="project-card">
            <h3>Student Management</h3>
            <p>CRUD application using JavaScript.</p>
        </div>

    </div>
</section>

<!-- Contact -->
<section id="contact">
    <h2>Contact Me</h2>

    <form id="contactForm">

        <input type="text" id="name" placeholder="Name">
        <span class="error" id="nameError"></span>

        <input type="email" id="email" placeholder="Email">
        <span class="error" id="emailError"></span>

        <input type="text" id="subject" placeholder="Subject">
        <span class="error" id="subjectError"></span>

        <textarea id="message" placeholder="Message"></textarea>
        <span class="error" id="messageError"></span>

        <button type="submit">Submit</button>

    </form>
</section>

<!-- Footer -->
<footer>
    <p>Follow Me</p>

    <a href="#">Facebook</a> |
    <a href="#">LinkedIn</a> |
    <a href="#">GitHub</a>

    <p>&copy; 2026 My Portfolio</p>
</footer>

<script src="script.js"></script>

</body>
</html>
